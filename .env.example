# ── Required ──────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=123456789

# ── Optional ──────────────────────────────────────────────────────────────────
# Database URL — defaults to local SQLite. For Railway use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Cost per conversion in ₽
PAYMENT_RATE=10.0

# CryptoBot API token (from @CryptoBot → My Apps)
# Leave empty to disable crypto payments
CRYPTOBOT_TOKEN=

# Public HTTPS URL of your Railway deployment (for Telegram Mini Apps)
# Example: https://your-app.up.railway.app
# Leave empty to disable font/color picker mini-apps
WEBAPP_URL=
